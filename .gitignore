# --- [ 核心依赖与构建产物 ] ---
node_modules/
dist/
dist-ssr/
# Vite PWA 插件在开发模式下生成的临时目录
dev-dist/
# 缓存目录
.cache/
.parcel-cache/
.eslintcache/

# --- [ 环境变量与私密信息 ] ---
# 包含敏感 Key 的本地环境文件（绝对不上传）
.env.local
.env.*.local
# 数据库或 Firebase 等私钥
*.pem
*.key

# --- [ 日志与调试文件 ] ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- [ 系统与编辑器配置 ] ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
# 白名单：保留团队通用的 VSCode 插件推荐
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- [ 测试相关 ] ---
/coverage
/test-results

# --- [ TypeScript 编译状态 ] ---
*.tsbuildinfo